@model List<TimeAnomalyWeb.Models.TimeData>

<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            margin: 0;
            font-family: Arial;
            background: white;
            color: #333;
        }

        .layout {
            display: flex;
        }

        /* SIDEBAR */
        .sidebar {
            width: 240px;
            height: 100vh;
            background: white;
            padding: 20px;
            position: fixed;
            top: 0;
            left: 0;
            transform: translateX(-260px);
            transition: transform 0.3s ease;
            z-index: 1000;
        }

            .sidebar.open {
                transform: translateX(0);
            }

            .sidebar h2 {
                color: #38bdf8;
            }

            .sidebar ul {
                list-style: none;
                padding: 12px;
                margin-top: 20px;
            }

                .sidebar ul li {
                    padding: 12px;
                    margin: 10px 0;
                    background: #f0f8ff;
                    border-radius: 8px;
                    cursor: pointer;
                    text-align: center;
                }

                    .sidebar ul li:hover {
                        background: #b0c4de;
                    }

        .upload-box {
            margin-top: 20px;
            background: #f0f8ff;
            padding: 15px;
            border-radius: 10px;
            text-align: center;
        }

        .upload-text {
            margin-bottom: 10px;
            font-size: 14px;
        }

        .file-label {
            display: block;
            background: #f0f8ff;
            padding: 8px;
            border-radius: 6px;
            cursor: pointer;
            margin-bottom: 10px;
        }

            .file-label:hover {
                background: #b0c4de;
            }

        .upload-btn {
            width: 100%;
            padding: 8px;
            background: #38bdf8;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            color: white;
            font-weight: bold;
        }

            .upload-btn:hover {
                background: #0ea5e9;
            }

        /* OVERLAY */
        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.3);
            display: none;
            z-index: 999;
        }

            .overlay.active {
                display: block;
            }

        /* MAIN */
        .main {
            flex: 1;
            padding: 20px;
        }

        .topbar {
            position: relative;
            display: flex;
            align-items: center;
            padding: 10px 0;
        }

        .title-center {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            font-size: 32px;
            color: #38bdf8;
        }


        .menu-btn {
            font-size: 22px;
            cursor: pointer;
            background: #38bdf8;
            padding: 6px 12px;
            border-radius: 6px;
            color: white;
        }

        .cards {
            display: flex;
            gap: 20px;
            margin: 20px 0;
        }

        .card {
            flex: 1;
            background: #f0f8ff;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
        }

        .chart-box {
            background: #f0f8ff;
            padding: 20px;
            border-radius: 12px;
        }

        table {
            width: 100%;
            margin-top: 20px;
            border-collapse: collapse;
        }

        th, td {
            padding: 10px;
            border-bottom: 1px solid #ccc;
        }

        .anomaly {
            background: #ef4444;
            color: white;
        }

        .empty-msg {
            color: orange;
            margin-top: 20px;
        }
    </style>
</head>

<body>

    <!-- OVERLAY -->
    <div id="overlay" class="overlay" onclick="toggleSidebar()"></div>

    <div class="layout">

        <!-- SIDEBAR -->
        <div class="sidebar" id="sidebar">
            <h2>⚡ Anomaly</h2>

            <div class="upload-box">
                <p class="upload-text">Upload CSV</p>

                <form method="post" enctype="multipart/form-data" asp-action="Upload">
                    <input type="file" name="file" id="fileInput" hidden />
                    <label for="fileInput" class="file-label">Choose File</label>
                    <p id="fileName" style="font-size:12px;"></p>
                    <button type="submit" class="upload-btn">Upload</button>
                </form>
            </div>

            <ul>
                <li>📊 Dashboard</li>
                <li onclick="location.href='/History'">📜 History</li>
                <li>📈 Analytics</li>
                <li>📁 Reports</li>
                <li>⚙ Settings</li>
            </ul>
        </div>

        <!-- MAIN -->
        <div class="main">

            <div class="topbar">
                <span class="menu-btn" onclick="toggleSidebar()">☰ MENU</span>
                <h1 class="title-center">Time Anomaly Dashboard</h1>
            </div>

            <p>@DateTime.Now</p>

            @if (TempData["LastUpload"] != null)
            {
                <p>Last Upload: @TempData["LastUpload"]</p>
            }

            @if (Model == null || !Model.Any())
            {
                <p class="empty-msg">Upload a CSV file to view data</p>
            }

            <div class="cards">
                <div class="card">
                    <h2>@(Model?.Count ?? 0)</h2>
                    <p>Total Data</p>
                </div>

                <div class="card">
                    <h2>@(Model != null && Model.Any() ? Model.Count(x => x.IsAnomaly) : 0)</h2>
                    <p>Anomalies</p>
                </div>

                <div class="card">
                    <h2>@(Model != null && Model.Any() ? Model.Average(x => x.Value).ToString("0.0") : "0")</h2>
                    <p>Average</p>
                </div>
            </div>

            <div class="chart-box">
                <canvas id="chart"></canvas>
            </div>

            <table>
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Value</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null)
                    {
                        foreach (var item in Model)
                        {
                            <tr class="@(item.IsAnomaly ? "anomaly" : "")">
                                <td>@item.Timestamp</td>
                                <td>@item.Value</td>
                                <td>@(item.IsAnomaly ? "⚠" : "✔")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

        </div>
    </div>

    <script>
        document.getElementById("fileInput").addEventListener("change", function () {
            document.getElementById("fileName").innerText = this.files[0]?.name || "";
        });

        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const overlay = document.getElementById("overlay");

            sidebar.classList.toggle("open");
            overlay.classList.toggle("active");
        }

        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                        Model?.Select(x => x.Timestamp.ToShortTimeString()) ?? new List<string>()
                ));

        const values = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                        Model?.Select(x => x.Value) ?? new List<double>()
                ));

        const colors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                        Model?.Select(x => x.IsAnomaly ? "red" : "#38bdf8") ?? new List<string>()
                ));

        new Chart(document.getElementById('chart'), {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Values',
                    data: values,
                    borderColor: '#38bdf8',
                    backgroundColor: 'transparent',
                    pointBackgroundColor: colors,
                    pointRadius: 5
                }]
            }
        });
    </script>

</body>
</html>