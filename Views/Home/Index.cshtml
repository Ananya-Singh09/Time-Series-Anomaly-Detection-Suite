@model List<TimeAnomalyWeb.Models.TimeData>

<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            margin: 0;
            font-family: Arial;
            background: #0f172a;
            color: white;
        }

        .layout {
            display: flex;
        }

        .sidebar {
            width: 220px;
            height: 100vh;
            background: #020617;
            padding: 20px;
        }

            .sidebar h2 {
                color: #38bdf8;
            }

            .sidebar ul {
                list-style: none;
                padding: 0;
            }

                .sidebar ul li {
                    padding: 12px;
                    margin: 10px 0;
                    background: #1e293b;
                    border-radius: 8px;
                    cursor: pointer;
                }

                    .sidebar ul li:hover {
                        background: #334155;
                    }

        .main {
            flex: 1;
            padding: 20px;
        }

        .topbar {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .cards {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        .card {
            flex: 1;
            background: #1e293b;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
        }

        .chart-box {
            background: #1e293b;
            padding: 20px;
            border-radius: 12px;
        }

        table {
            width: 100%;
            margin-top: 20px;
            border-collapse: collapse;
        }

        th, td {
            padding: 10px;
            border-bottom: 1px solid #334155;
        }

        .anomaly {
            background: #ef4444;
        }
    </style>
</head>

<body>

    <div class="layout">

        <div class="sidebar">
            <h2>⚡ Anomaly</h2>
            <ul>
                <li>Dashboard</li>
                <li>Analytics</li>
                <li>Reports</li>
                <li>Settings</li>
            </ul>
        </div>

        <div class="main">

            <div class="topbar">
                <h1>Time Anomaly Dashboard</h1>
                <p>@DateTime.Now</p>
            </div>

            <div class="cards">
                <div class="card">
                    <h2>@Model.Count</h2>
                    <p>Total Data</p>
                </div>

                <div class="card">
                    <h2>@Model.Count(x => x.IsAnomaly)</h2>
                    <p>Anomalies</p>
                </div>

                <div class="card">
                    <h2>@Model.Average(x => x.Value).ToString("0.0")</h2>
                    <p>Average</p>
                </div>
            </div>

            <div class="chart-box">
                <canvas id="chart"></canvas>
            </div>

            <table>
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Value</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.IsAnomaly ? "anomaly" : "")">
                            <td>@item.Timestamp</td>
                            <td>@item.Value</td>
                            <td>@(item.IsAnomaly ? "⚠" : "✔")</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

    <script>
        const labels = [
            @foreach (var item in Model)
            {
                    @: "@item.Timestamp.ToShortTimeString()",
            }
        ];

        const values = [
            @foreach (var item in Model)
            {
                    @: @item.Value,
            }
        ];

        const anomalyColors = [
            @foreach (var item in Model)
            {
                    @: "@(item.IsAnomaly ? "red" : "#38bdf8")",
            }
        ];

        new Chart(document.getElementById('chart'), {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Values',
                    data: values,
                    borderColor: '#38bdf8',
                    backgroundColor: 'transparent',
                    pointBackgroundColor: anomalyColors,
                    pointRadius: 5
                }]
            }
        });
    </script>

</body>
</html>
