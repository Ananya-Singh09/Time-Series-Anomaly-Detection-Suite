@model List<SimpleAnomalyDetector.Controllers.TimeData>

<!DOCTYPE html>
<html>
<head>
    <title>Simple Anomaly Detector</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body {
            font-family: Arial;
            margin: 20px;
            background: #f5f5f5;
        }

        .container {
            max-width: 1200px;
            margin: auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
        }

        .btn {
            background: #4CAF50;
            color: white;
            padding: 10px 20px;
            border: none;
            cursor: pointer;
            margin: 5px;
            border-radius: 5px;
        }

        .btn-danger {
            background: #f44336;
        }

        .stats {
            display: flex;
            gap: 20px;
            margin: 20px 0;
        }

        .stat {
            background: #2196F3;
            color: white;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
            flex: 1;
        }

            .stat h3 {
                margin: 0 0 10px 0;
            }

            .stat .number {
                font-size: 32px;
                font-weight: bold;
                margin: 0;
            }

        canvas {
            max-height: 400px;
            margin: 20px 0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th, td {
            padding: 10px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        th {
            background: #2196F3;
            color: white;
        }

        .anomaly {
            background: #ffebee;
            color: #f44336;
            font-weight: bold;
        }

        .alert {
            padding: 10px;
            margin: 10px 0;
            border-radius: 5px;
        }

        .success {
            background: #d4edda;
            color: #155724;
        }

        .error {
            background: #f8d7da;
            color: #721c24;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Time Anomaly Detection Suite</h1>

        <form method="post" action="/Home/Upload" enctype="multipart/form-data">
            <input type="file" name="file" accept=".csv" required />
            <button type="submit" class="btn">Upload & Detect</button>
            <a href="/Home/Clear"><button type="button" class="btn btn-danger">Clear Data</button></a>
        </form>

        @if (TempData["Success"] != null)
        {
            <div class="alert success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert error">@TempData["Error"]</div>
        }

        @if (Model != null && Model.Count > 0)
        {
            <div class="stats">
                <div class="stat">
                    <h3>Total Records</h3>
                    <p class="number">@Model.Count</p>
                </div>
                <div class="stat" style="background: #f44336;">
                    <h3>Anomalies</h3>
                    <p class="number">@Model.Count(x => x.IsAnomaly)</p>
                </div>
                <div class="stat" style="background: #4CAF50;">
                    <h3>Normal</h3>
                    <p class="number">@Model.Count(x => !x.IsAnomaly)</p>
                </div>
            </div>

            <canvas id="chart"></canvas>

            <div style="max-height: 400px; overflow-y: auto;">
                <table>
                    <thead>
                        <tr><th>#</th><th>Time</th><th>Value</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="@(item.IsAnomaly ? "anomaly" : "")">
                                <td>@item.Id</td>
                                <td>@item.Timestamp.ToString("HH:mm:ss")</td>
                                <td>@item.Value.ToString("F2")</td>
                                <td>@(item.IsAnomaly ? "⚠️ ANOMALY" : "✓ NORMAL")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <script>
                const labels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Select(x => x.Timestamp.ToString("HH:mm:ss")).ToList()));
                const values = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Select(x => x.Value).ToList()));
                const anomalies = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Select(x => x.IsAnomaly ? x.Value : (double?)null).ToList()));

                new Chart(document.getElementById('chart'), {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [
                            { label: 'Data', data: values, borderColor: 'blue', backgroundColor: 'rgba(0,0,255,0.1)', fill: true },
                            { label: 'Anomalies', data: anomalies, borderColor: 'red', backgroundColor: 'red', type: 'scatter', pointRadius: 8, showLine: false }
                        ]
                    },
                    options: { responsive: true, maintainAspectRatio: true }
                });
            </script>
        }
        else
        {
            <div style="text-align: center; padding: 60px;">
                <h3>No Data Available</h3>
                <p>Upload a CSV file to begin</p>
                <p><strong>Example CSV:</strong><br />100<br />102<br />250<br />103</p>
            </div>
        }
    </div>
</body>
</html>